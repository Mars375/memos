{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "zai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Z.AI / GLM",
      "options": {
        "baseURL": "https://api.z.ai/api/coding/paas/v4/",
        "apiKey": "{env:GLM_API_KEY}"
      },
      "models": {
        "glm-5.1": {
          "name": "GLM 5.1",
          "limit": { "context": 128000, "output": 16384 }
        },
        "glm-5-turbo": {
          "name": "GLM 5 Turbo",
          "limit": { "context": 128000, "output": 16384 }
        }
      }
    }
  },
  "instructions": ["AGENTS.md"]
}
